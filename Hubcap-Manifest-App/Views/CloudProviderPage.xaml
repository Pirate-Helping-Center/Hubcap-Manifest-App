<UserControl x:Class="HubcapManifestApp.Views.CloudProviderPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <Grid Margin="0,10,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Choose where CloudRedirect stores your cloud saves."
                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,15"/>
        <Border Grid.Row="1" Style="{StaticResource ModernCardStyle}" Margin="0,0,0,10">
            <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                <TextBlock Text="Select Provider" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <ComboBox SelectedValue="{Binding SelectedProvider}" SelectedValuePath="Tag" Margin="0,0,0,15">
                    <ComboBoxItem Content="Google Drive" Tag="gdrive"/>
                    <ComboBoxItem Content="OneDrive" Tag="onedrive"/>
                    <ComboBoxItem Content="Folder / Network Drive" Tag="folder"/>
                    <ComboBoxItem Content="Local Only" Tag="local"/>
                </ComboBox>

                <!-- Folder path (visible for folder provider) -->
                <StackPanel Visibility="{Binding ShowPathInput, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,15">
                    <TextBlock Text="Sync Folder Path" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding SyncPath}" IsReadOnly="True" Padding="8,6" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Browse" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding BrowsePathCommand}" Padding="15,6"/>
                    </Grid>
                </StackPanel>

                <!-- OAuth sign-in (visible for gdrive/onedrive) -->
                <StackPanel Visibility="{Binding ShowSignIn, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,15">
                    <WrapPanel Orientation="Horizontal">
                        <Button Command="{Binding SignInCommand}" Padding="20,8" Margin="0,0,8,0"
                                IsEnabled="{Binding IsAuthenticating, Converter={StaticResource InverseBooleanConverter}}">
                            <StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="LogIn" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Sign In" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CancelAuthCommand}" Padding="15,8"
                                Visibility="{Binding IsAuthenticating, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Cancel"/>
                        </Button>
                    </WrapPanel>
                </StackPanel>

                <!-- Auth status -->
                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" Padding="12,8" Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconLucide Kind="Info" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding AuthStatus}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                    </StackPanel>
                </Border>

                <Button Command="{Binding SaveConfigCommand}" Padding="20,8">
                    <StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="Save" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Save Configuration" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Auth log -->
        <Border Grid.Row="2" Style="{StaticResource ModernCardStyle}"
                Visibility="{Binding IsAuthenticating, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True" Background="Transparent"
                         BorderThickness="0" Foreground="{DynamicResource TextSecondaryBrush}"
                         FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" AcceptsReturn="True"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="HubcapManifestApp.Views.CloudModePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Loaded="OnLoaded">
    <Grid Margin="0,10,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select how CloudRedirect handles your saves."
                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,15"/>

        <WrapPanel Grid.Row="1" Orientation="Horizontal">
            <!-- STFixer Card -->
            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,10,10" MinWidth="280" MaxWidth="350" Cursor="Hand"
                    MouseLeftButtonUp="StFixerCard_Click">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <iconPacks:PackIconLucide Kind="Shield" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="STFixer Mode" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                    <TextBlock Text="Standard mode. Fixes issues saving in most Capcom games and some others without enabling save syncing to a cloud provider. Also enables the ability to use manifest pinning."
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SecondaryDarkBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStFixerMode}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="11" Foreground="White">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Select"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStFixerMode}" Value="True">
                                            <Setter Property="Text" Value="Active"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>

            <!-- CloudRedirect Card -->
            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,10" MinWidth="280" MaxWidth="350" Cursor="Hand"
                    MouseLeftButtonUp="CloudRedirectCard_Click">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <iconPacks:PackIconLucide Kind="Cloud" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="CloudRedirect Mode" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                    <TextBlock Text="Redirects Steam Cloud saves to Google Drive, OneDrive, or a local folder. Experimental — back up your saves first."
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SecondaryDarkBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCloudRedirectMode}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="11" Foreground="White">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Select"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCloudRedirectMode}" Value="True">
                                            <Setter Property="Text" Value="Active"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>
        </WrapPanel>
    </Grid>
</UserControl>

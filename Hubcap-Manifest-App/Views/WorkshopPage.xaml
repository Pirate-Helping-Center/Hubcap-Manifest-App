<UserControl x:Class="HubcapManifestApp.Views.WorkshopPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Workshop Downloader"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,15"/>

        <!-- Input Section -->
        <Border Grid.Row="1" Style="{StaticResource ModernCardStyle}" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Workshop IDs or Steam URLs"
                           FontSize="14"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,6"/>
                <TextBlock Text="Paste Workshop IDs, Steam Workshop URLs, or a mix — one per line or comma-separated"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,8"/>
                <TextBox Text="{Binding WorkshopIdsText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Height="100"
                         Padding="8"/>
            </StackPanel>
        </Border>

        <!-- Options -->
        <Border Grid.Row="2" Style="{StaticResource ModernCardStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Max Downloads:"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding MaxDownloads, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=False}"
                         Width="50" Padding="8,6" VerticalContentAlignment="Center"
                         Margin="0,0,20,0"
                         Validation.ErrorTemplate="{x:Null}"/>

                <TextBlock Grid.Column="2" Text="Output:"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="3"
                         Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="True" Padding="8,6" VerticalContentAlignment="Center"
                         Margin="0,0,8,0"/>
                <Button Grid.Column="4"
                        Content="Browse"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding BrowseOutputCommand}"
                        Padding="15,6"/>
            </Grid>
        </Border>

        <!-- Action Bar -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding DownloadCommand}"
                        IsEnabled="{Binding IsDownloading, Converter={StaticResource InverseBooleanConverter}}"
                        Padding="20,8"
                        Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconLucide Kind="Download" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Download" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ClearLogCommand}"
                        Padding="15,8">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconLucide Kind="Trash2" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Clear Log" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       FontSize="12"/>
        </Grid>

        <!-- Log Output -->
        <Border Grid.Row="4" Style="{StaticResource ModernCardStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox Text="{Binding LogText, Mode=OneWay}"
                         IsReadOnly="True"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         FontFamily="Consolas"
                         FontSize="12"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Disabled"
                         CaretBrush="{DynamicResource TextPrimaryBrush}"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>

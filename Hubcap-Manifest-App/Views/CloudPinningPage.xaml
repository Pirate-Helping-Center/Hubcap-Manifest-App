<UserControl x:Class="HubcapManifestApp.Views.CloudPinningPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Loaded="OnLoaded">
    <Grid Margin="0,10,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Pin specific games to prevent their manifests from being updated automatically."
                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,15"/>

        <!-- Toggles -->
        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <CheckBox Content="Enable Manifest Pinning" IsChecked="{Binding ManifestPinningEnabled}" Margin="0,0,20,0"/>
            <CheckBox Content="Auto-comment pinned depots" IsChecked="{Binding AutoCommentEnabled}" Margin="0,0,20,0"/>
            <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RefreshCommand}" Padding="15,8">
                <StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="RefreshCw" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Refresh" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel>
            </Button>
            <TextBlock Text="Changes auto-saved" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                       VerticalAlignment="Center" Margin="12,0,0,0" Opacity="0.6" FontStyle="Italic"/>
        </WrapPanel>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>

        <!-- App List -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Apps}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Checkbox -->
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsPinned}" VerticalAlignment="Center" Margin="0,0,12,0"/>

                                <!-- Game header image -->
                                <Border Grid.Column="1" Background="{DynamicResource SecondaryDarkBrush}"
                                        CornerRadius="6" Width="180" Height="84" Margin="0,0,12,0"
                                        VerticalAlignment="Center">
                                    <Grid>
                                        <Image Source="{Binding CachedIconPath}"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="LowQuality"
                                               Visibility="{Binding CachedIconPath, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        <iconPacks:PackIconLucide Kind="Gamepad2" Width="32" Height="32"
                                                                  Foreground="{DynamicResource AccentBrush}"
                                                                  VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                  Visibility="{Binding CachedIconPath, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                                    </Grid>
                                </Border>

                                <!-- Name + stats -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                        <TextBlock Text="{Binding AppId, StringFormat='AppID {0}'}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                                        <TextBlock Text="{Binding DepotSummary}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Pin icon -->
                                <iconPacks:PackIconLucide Grid.Column="3" Width="16" Height="16" VerticalAlignment="Center">
                                    <iconPacks:PackIconLucide.Style>
                                        <Style TargetType="iconPacks:PackIconLucide" BasedOn="{StaticResource {x:Type iconPacks:PackIconLucide}}">
                                            <Setter Property="Kind" Value="Pin"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </iconPacks:PackIconLucide.Style>
                                </iconPacks:PackIconLucide>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>

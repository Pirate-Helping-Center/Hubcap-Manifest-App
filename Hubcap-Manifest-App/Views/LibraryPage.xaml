<UserControl x:Class="HubcapManifestApp.Views.LibraryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:models="clr-namespace:HubcapManifestApp.Models">
    <Grid Margin="30"
          AllowDrop="True"
          Drop="Grid_Drop"
          DragEnter="Grid_DragEnter"
          DragLeave="Grid_DragLeave">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header + Stats -->
            <RowDefinition Height="Auto"/>
            <!-- Search and Filters -->
            <RowDefinition Height="Auto"/>
            <!-- Batch Actions Bar -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Pagination -->
        </Grid.RowDefinitions>

        <!-- Header with inline stats -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                <TextBlock Text="Library"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>
                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="14,6" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding TotalLua}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text=" Lua" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                        <TextBlock Text="{Binding TotalSteamGames}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text=" Steam" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                        <TextBlock FontWeight="Bold" FontSize="14" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center">
                            <TextBlock.Text><Binding Path="TotalSize" Converter="{StaticResource BytesToStringConverter}"/></TextBlock.Text>
                        </TextBlock>
                        <TextBlock Text=" Size" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Action Buttons -->
            <WrapPanel Orientation="Horizontal" Margin="0,0,0,0">
                <Button Command="{Binding RefreshLibraryCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,6"><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="RefreshCw" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Refresh" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel></Button>
                <Button Command="{Binding UpdateSteamAppCacheCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,6"
                        ToolTip="Refresh game names and icons from Steam's database"><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="Package" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Refresh Cache" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel></Button>
                <Button Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ToggleAutoUpdatesCommand}"
                        Margin="0,0,8,6"
                        ToolTip="Toggle auto-updates for all lua games (SteamTools mode only)"
                        Visibility="{Binding IsSteamToolsMode, Converter={StaticResource BooleanToVisibilityConverter}}"><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="RefreshCw" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Toggle Updates" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel></Button>
                <Button Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ExportLuasCommand}"
                        Margin="0,0,8,6"
                        ToolTip="Export all lua files to a ZIP archive for backup or sharing"><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="FolderOutput" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Export Luas" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel></Button>
                <Button Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding RestartSteamCommand}"
                        Margin="0,0,0,6"
                        ToolTip="Restart Steam"><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="RefreshCw" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Restart Steam" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel></Button>
            </WrapPanel>
        </StackPanel>

        <!-- Search and Filters -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="150"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search Box -->
            <Grid Grid.Column="0" Margin="0,0,10,0" MinWidth="150">
                <Border Height="34"
                        Background="{DynamicResource SecondaryDarkBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <iconPacks:PackIconLucide Grid.Column="0"
                                                  Kind="Search"
                                                  Width="14" Height="14"
                                                  VerticalAlignment="Center"
                                                  Margin="8,0,4,0"
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  IsHitTestVisible="False"/>
                        <Grid Grid.Column="1">
                            <TextBox x:Name="LibrarySearchBox"
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="13"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     CaretBrush="{DynamicResource TextPrimaryBrush}"
                                     Padding="0,0,8,0"
                                     VerticalContentAlignment="Center"/>
                            <TextBlock Text="Search by name, App ID, or description..."
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="2,0,8,0"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=LibrarySearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Filter ComboBox -->
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding FilterOptions}"
                      SelectedItem="{Binding SelectedFilter}"
                      Width="150"
                      MinHeight="0"
                      Height="34"
                      Margin="0,0,10,0"
                      Padding="8,5"
                      FontSize="12"/>

            <!-- Sort ComboBox -->
            <ComboBox Grid.Column="2"
                      ItemsSource="{Binding SortOptions}"
                      SelectedItem="{Binding SelectedSort}"
                      Width="150"
                      MinHeight="0"
                      Height="34"
                      Margin="0,0,10,0"
                      Padding="8,5"
                      FontSize="12"/>

            <!-- View Toggle -->
            <Button Grid.Column="3"
                    Command="{Binding ToggleViewCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Height="34"
                    Padding="10,5"
                    Margin="0,0,10,0">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconLucide Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0">
                            <iconPacks:PackIconLucide.Style>
                                <Style TargetType="iconPacks:PackIconLucide" BasedOn="{StaticResource {x:Type iconPacks:PackIconLucide}}">
                                    <Setter Property="Kind" Value="LayoutGrid"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsListView}" Value="True">
                                            <Setter Property="Kind" Value="List"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </iconPacks:PackIconLucide.Style>
                        </iconPacks:PackIconLucide>
                        <TextBlock VerticalAlignment="Center"
                                   Text="{Binding IsListView, Converter={StaticResource BoolToViewTextConverter}, Mode=OneWay}"/>
                    </StackPanel>
                </Button.Content>
            </Button>

            <!-- Select Mode Toggle -->
            <Button Grid.Column="4"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding ToggleSelectModeCommand}"
                    Height="34"
                    Padding="10,5"
                    Margin="0,0,10,0"><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="SquareCheck" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Select Mode" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel></Button>
        </Grid>

        <!-- Batch Actions Bar (Visible in Select Mode) -->
        <Border Grid.Row="2"
                Background="{DynamicResource SecondaryDarkBrush}"
                Padding="15"
                CornerRadius="8"
                Margin="0,0,0,15"
                Visibility="{Binding IsSelectMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Select All"
                            Command="{Binding SelectAllCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="12,6"
                            Margin="0,0,10,0"/>
                    <Button Content="Deselect All"
                            Command="{Binding DeselectAllCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="12,6"
                            Margin="0,0,10,0"/>
                    <Button Command="{Binding UninstallSelectedCommand}"
                            Padding="12,6"><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="Trash2" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Uninstall Selected" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel></Button>
                </StackPanel>

                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Games Grid/List -->
        <ScrollViewer Grid.Row="3"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding DisplayedItems}">
                <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                        <Setter Property="ItemsPanel">
                            <Setter.Value>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsListView}" Value="True">
                                <Setter Property="ItemsPanel">
                                    <Setter.Value>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Vertical"/>
                                        </ItemsPanelTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.Style>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource ModernCardStyle}">
                                    <Setter Property="Width" Value="280"/>
                                    <Setter Property="Height" Value="350"/>
                                    <Setter Property="Margin" Value="0,0,20,20"/>
                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsListView, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                            <Setter Property="Width" Value="Auto"/>
                                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                            <Setter Property="Height" Value="Auto"/>
                                            <Setter Property="Margin" Value="0,0,0,6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Command="{Binding RunInSteamCommand}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"><MenuItem.Header><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="Play" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Run in Steam" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                                    <MenuItem Command="{Binding OpenSteamStorePageCommand}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"><MenuItem.Header><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="Store" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Open Steam Store Page" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                                    <Separator/>
                                    <MenuItem Command="{Binding ShowDetailsCommand}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"><MenuItem.Header><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="ClipboardList" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="View Details" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                                    <MenuItem Command="{Binding OpenInExplorerCommand}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"><MenuItem.Header><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="Folder" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Open in Explorer" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                                    <MenuItem Command="{Binding CopyAppIdCommand}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"><MenuItem.Header><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="Copy" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Copy AppID" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                                    <Separator/>
                                    <MenuItem Command="{Binding FixGameCommand}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"><MenuItem.Header><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="Wrench" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Fix Game" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                                    <Separator/>
                                    <MenuItem Command="{Binding UninstallItemCommand}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"><MenuItem.Header><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="Trash2" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Uninstall" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                                </ContextMenu>
                            </Border.ContextMenu>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Game Image Container -->
                                <Grid Visibility="{Binding DataContext.HideHeaderImages, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Grid.Row" Value="0"/>
                                            <Setter Property="Grid.Column" Value="0"/>
                                            <Setter Property="Grid.ColumnSpan" Value="3"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsListView, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                    <Setter Property="Grid.Row" Value="0"/>
                                                    <Setter Property="Grid.Column" Value="0"/>
                                                    <Setter Property="Grid.ColumnSpan" Value="1"/>
                                                    <Setter Property="Grid.RowSpan" Value="3"/>
                                                    <Setter Property="Margin" Value="2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>

                                    <!-- Game Image -->
                                    <Border Background="{DynamicResource SecondaryDarkBrush}"
                                            CornerRadius="8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Width" Value="280"/>
                                                <Setter Property="Height" Value="131"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsListView, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                        <Setter Property="Width" Value="180"/>
                                                        <Setter Property="Height" Value="84"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <!-- Show cached BitmapImage if available (optimized) -->
                                            <Image Source="{Binding CachedBitmapImage}"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="LowQuality"
                                                   Visibility="{Binding CachedBitmapImage, Converter={StaticResource NullToVisibilityConverter}}"/>

                                            <!-- Show from file path as fallback if BitmapImage not yet loaded -->
                                            <Image Source="{Binding CachedIconPath, Converter={StaticResource ImagePathConverter}}"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="LowQuality"
                                                   Visibility="{Binding CachedBitmapImage, Converter={StaticResource InverseNullToVisibilityConverter}}"/>

                                            <!-- Placeholder if no icon at all -->
                                            <iconPacks:PackIconLucide Kind="Gamepad2"
                                                       Width="64"
                                                       Height="64"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource AccentBrush}">
                                                <iconPacks:PackIconLucide.Style>
                                                    <Style TargetType="iconPacks:PackIconLucide">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding CachedBitmapImage, Converter={StaticResource NullToVisibilityConverter}}" Value="Collapsed"/>
                                                                    <Condition Binding="{Binding CachedIconPath, Converter={StaticResource NullToVisibilityConverter}}" Value="Collapsed"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </iconPacks:PackIconLucide.Style>
                                            </iconPacks:PackIconLucide>
                                        </Grid>
                                    </Border>

                                    <!-- Type Badge (Grid View only - overlaid on image) -->
                                    <Border Background="{DynamicResource BorderBrush}"
                                            Padding="8,4"
                                            CornerRadius="4"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="8"
                                            Visibility="{Binding DataContext.IsListView, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <TextBlock Text="{Binding TypeBadge}"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Foreground="White"/>
                                    </Border>

                                    <!-- Checkbox for Select Mode -->
                                    <CheckBox IsChecked="{Binding IsSelected}"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Top"
                                              Margin="10"
                                              Visibility="{Binding DataContext.IsSelectMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </Grid>

                                <!-- Game Info (Grid View) -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="10,8,10,5"
                                            Visibility="{Binding DataContext.IsListView, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               TextWrapping="Wrap"
                                               MaxHeight="60"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Text="{Binding AppId, StringFormat='App ID: {0}'}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,5,0,0"/>
                                </StackPanel>

                                <!-- Game Info (List View) -->
                                <Grid Grid.Row="0" Grid.Column="1" Grid.RowSpan="3" Margin="10" VerticalAlignment="Center"
                                      Visibility="{Binding DataContext.IsListView, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Top row: Badge + Name -->
                                    <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                                        <Border Background="{DynamicResource BorderBrush}"
                                                Padding="6,3"
                                                CornerRadius="4"
                                                VerticalAlignment="Center"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="{Binding TypeBadge}"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       Foreground="White"/>
                                        </Border>

                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                    </WrapPanel>

                                    <!-- Bottom row: Details -->
                                    <WrapPanel Grid.Row="1" Orientation="Horizontal">
                                        <TextBlock Text="{Binding AppId, StringFormat='App ID: {0}'}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>

                                        <TextBlock Text="{Binding SizeFormatted}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>

                                        <TextBlock FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding LastUpdated, Converter={StaticResource NullToVisibilityConverter}}">
                                            <Run Text="Updated:"/>
                                            <Run Text="{Binding LastUpdated, StringFormat='{}{0:MMM d}'}"/>
                                        </TextBlock>
                                    </WrapPanel>
                                </Grid>

                                <!-- Bottom Section (Grid View) - Pinned to bottom -->
                                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="10,5,10,10"
                                            Visibility="{Binding DataContext.IsListView, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                    <TextBlock FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,0,0,8"
                                               HorizontalAlignment="Center">
                                        <Run Text="{Binding SizeFormatted, Mode=OneWay}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding LastUpdated, StringFormat='Updated: {0:MMM d}', TargetNullValue='Not updated', Mode=OneWay}"/>
                                    </TextBlock>

                                    <!-- Install primary, shown only when the lua exists, the game isn't on disk,
                                         AND the app is in SteamTools mode (DepotDownloader mode has no
                                         equivalent install path and the button just makes no sense there). -->
                                    <Button Command="{Binding DataContext.InstallLuaGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,0,6">
                                        <Button.Visibility>
                                            <MultiBinding Converter="{StaticResource AllTrueToVisibilityConverter}">
                                                <Binding Path="IsLuaUninstalled"/>
                                                <Binding Path="DataContext.IsSteamToolsMode" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            </MultiBinding>
                                        </Button.Visibility>
                                        <StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="Download" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Install" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel>
                                    </Button>
                                    <!-- Refetch: shows when the lua doesn't match the tool's header format. -->
                                    <Button Command="{Binding DataContext.RefetchLuaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,0,6"
                                            Visibility="{Binding CanRefetchLua, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            ToolTip="This lua wasn't created by Hubcap Manifest App. Download a fresh copy from the API to overwrite it.">
                                        <StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="RefreshCw" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Refetch" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel>
                                    </Button>
                                    <Button Command="{Binding DataContext.UninstallItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Setter Property="Content" Value="Uninstall"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLuaUninstalled}" Value="True">
                                                        <Setter Property="Content" Value="Delete Lua"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>

                                <!-- Actions (List View) -->
                                <StackPanel Grid.Row="0" Grid.Column="2" Grid.RowSpan="3"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="10"
                                            Visibility="{Binding DataContext.IsListView, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Button Command="{Binding DataContext.InstallLuaGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Padding="15,8"
                                            Margin="0,0,8,0">
                                        <Button.Visibility>
                                            <MultiBinding Converter="{StaticResource AllTrueToVisibilityConverter}">
                                                <Binding Path="IsLuaUninstalled"/>
                                                <Binding Path="DataContext.IsSteamToolsMode" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            </MultiBinding>
                                        </Button.Visibility>
                                        <StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="Download" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Install" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel>
                                    </Button>
                                    <Button Command="{Binding DataContext.RefetchLuaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Padding="15,8"
                                            Margin="0,0,8,0"
                                            Visibility="{Binding CanRefetchLua, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            ToolTip="This lua wasn't created by Hubcap Manifest App. Download a fresh copy to overwrite it.">
                                        <StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="RefreshCw" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Refetch" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel>
                                    </Button>
                                    <Button Command="{Binding DataContext.UninstallItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Padding="15,8">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Setter Property="Content" Value="Uninstall"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLuaUninstalled}" Value="True">
                                                        <Setter Property="Content" Value="Delete Lua"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Pagination Controls -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,15,0,0">
            <Button Command="{Binding PreviousPageCommand}"
                    IsEnabled="{Binding CanGoPrevious}"
                    Padding="20,10"
                    FontSize="14"
                    Margin="0,0,10,0"><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="ArrowLeft" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Previous Page" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel></Button>

            <TextBlock Text="{Binding CurrentPage, StringFormat='Page {0} of'}"
                       FontSize="14"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"
                       Margin="10,0,5,0"/>

            <TextBlock Text="{Binding TotalPages}"
                       FontSize="14"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

            <Button Command="{Binding NextPageCommand}"
                    IsEnabled="{Binding CanGoNext}"
                    Padding="20,10"
                    FontSize="14"
                    Margin="10,0,0,0"><StackPanel Orientation="Horizontal"><TextBlock Text="Next Page" VerticalAlignment="Center" Margin="0,0,6,0"/><iconPacks:PackIconLucide Kind="ArrowRight" Width="14" Height="14" VerticalAlignment="Center"/></StackPanel></Button>
        </StackPanel>

        <!-- Loading Overlay -->
        <Grid Grid.Row="3"
              Grid.RowSpan="2"
              Background="#AA000000"
              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <iconPacks:PackIconLucide Kind="Hourglass" Width="48" Height="48" Margin="0,0,0,10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock Text="Loading library..."
                           FontSize="18"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="HubcapManifestApp.Views.CloudDashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Loaded="OnLoaded">
    <Grid Margin="0,10,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Overview of your CloudRedirect configuration and patch status."
                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,15"/>

        <!-- Status Cards -->
        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,10,10" MinWidth="220">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <iconPacks:PackIconLucide Kind="Cloud" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Cloud Provider" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding ProviderStatus}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                    <TextBlock Text="{Binding ProviderDetail}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                               Margin="0,2,0,0" TextTrimming="CharacterEllipsis" Opacity="0.7"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,10,10" MinWidth="220">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <iconPacks:PackIconLucide Kind="HardDrive" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Steam Path" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding SteamPath}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,10,10" MinWidth="160">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <iconPacks:PackIconLucide Kind="Gamepad2" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Apps Syncing" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding AppCount}" Foreground="{DynamicResource AccentBrush}" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,10" MinWidth="200">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <iconPacks:PackIconLucide Kind="Plug" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="CloudRedirect DLL" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding DllStatus}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Patch State Cards -->
        <WrapPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,10,10" MinWidth="180">
                <StackPanel>
                    <TextBlock Text="Core Patch" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding CorePatchState}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,10,10" MinWidth="180">
                <StackPanel>
                    <TextBlock Text="Offline Setup" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding OfflinePatchState}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,10" MinWidth="180">
                <StackPanel>
                    <TextBlock Text="SteamTools.exe" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SteamToolsPatchState}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Quick Actions -->
        <WrapPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RefreshCommand}" Padding="15,8" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="RefreshCw" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Refresh" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel>
            </Button>
            <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding OpenLogCommand}" Padding="15,8" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="FileText" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Open Log" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel>
            </Button>
            <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RestartSteamCommand}" Padding="15,8" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="RefreshCw" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Restart Steam" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel>
            </Button>
            <Button Command="{Binding UpdateDllCommand}" Padding="15,8" Margin="0,0,8,0"
                    Visibility="{Binding DllNeedsUpdate, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="Download" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Update DLL" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel>
            </Button>
            <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RevertAllPatchesCommand}" Padding="15,8"
                    Visibility="{Binding IsAnyPatched, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="Undo2" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Revert All Patches" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel>
            </Button>
        </WrapPanel>
    </Grid>
</UserControl>

<UserControl x:Class="HubcapManifestApp.Views.CloudExperimentalPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Loaded="OnLoaded">
    <Grid Margin="0,10,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Control what data is synced between your PCs via the cloud provider. Changes take effect after restarting Steam."
                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,15"/>

        <!-- Not in CloudRedirect mode warning -->
        <Border Grid.Row="1" CornerRadius="6" Margin="0,0,0,15"
                Visibility="{Binding IsCloudRedirectMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <Grid>
                <Border CornerRadius="6" Background="{DynamicResource WarningBrush}" Opacity="0.15"/>
                <StackPanel Orientation="Horizontal" Margin="12,8">
                    <iconPacks:PackIconLucide Kind="TriangleAlert" Width="16" Height="16" VerticalAlignment="Center"
                                              Foreground="{DynamicResource WarningBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="Sync settings are only available in CloudRedirect mode. Switch to CloudRedirect mode on the Mode tab first."
                               Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sync toggle cards -->
        <StackPanel Grid.Row="2" Visibility="{Binding IsCloudRedirectMode, Converter={StaticResource BooleanToVisibilityConverter}}">

            <!-- Achievement sync -->
            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <iconPacks:PackIconLucide Grid.Column="0" Kind="Trophy" Width="24" Height="24"
                                              VerticalAlignment="Center" Margin="0,0,12,0"
                                              Foreground="{DynamicResource AccentBrush}"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Sync achievements" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Upload and merge achievement progress for lua apps across PCs."
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" Margin="0,3,0,0"/>
                    </StackPanel>

                    <CheckBox Grid.Column="2" IsChecked="{Binding SyncAchievements}"
                              VerticalAlignment="Center" Margin="12,0,0,0"/>
                </Grid>
            </Border>

            <!-- Playtime sync -->
            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <iconPacks:PackIconLucide Grid.Column="0" Kind="Clock" Width="24" Height="24"
                                              VerticalAlignment="Center" Margin="0,0,12,0"
                                              Foreground="{DynamicResource AccentBrush}"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Sync playtime" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Upload and merge playtime data for lua apps across PCs."
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" Margin="0,3,0,0"/>
                    </StackPanel>

                    <CheckBox Grid.Column="2" IsChecked="{Binding SyncPlaytime}"
                              VerticalAlignment="Center" Margin="12,0,0,0"/>
                </Grid>
            </Border>

            <!-- Lua file sync -->
            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <iconPacks:PackIconLucide Grid.Column="0" Kind="FileCode" Width="24" Height="24"
                                              VerticalAlignment="Center" Margin="0,0,12,0"
                                              Foreground="{DynamicResource AccentBrush}"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Sync lua files" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Sync lua files themselves between PCs so you don't have to install them again."
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" Margin="0,3,0,0"/>
                    </StackPanel>

                    <CheckBox Grid.Column="2" IsChecked="{Binding SyncLuas}"
                              VerticalAlignment="Center" Margin="12,0,0,0"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="12" FontStyle="Italic" Margin="0,4,0,0" VerticalAlignment="Top"/>
    </Grid>
</UserControl>

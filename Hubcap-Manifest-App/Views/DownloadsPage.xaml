<UserControl x:Class="HubcapManifestApp.Views.DownloadsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:models="clr-namespace:HubcapManifestApp.Models">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Downloads"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>

            <Button Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding OpenDownloadsFolderCommand}"
                    HorizontalAlignment="Right"><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="Folder" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Open Folder" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel></Button>
        </Grid>

        <!-- Active Downloads Section -->
        <TextBlock Grid.Row="1"
                   Text="Active Downloads"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      Margin="0,0,0,20">
            <ItemsControl ItemsSource="{Binding ActiveDownloads}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ModernCardStyle}"
                                Margin="0,0,0,15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <TextBlock Text="{Binding GameName}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                                    <TextBlock Text="{Binding StatusMessage}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Right"/>
                                </Grid>

                                <ProgressBar Grid.Row="1"
                                             Value="{Binding Progress}"
                                             Maximum="100"
                                             Height="8"
                                             Margin="0,10,0,5"/>

                                <Grid Grid.Row="2">
                                    <TextBlock FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} / {1}">
                                                <Binding Path="DownloadedFormatted" Mode="OneWay"/>
                                                <Binding Path="TotalFormatted" Mode="OneWay"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right">
                                        <Button Content="Cancel"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding DataContext.CancelDownloadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Padding="10,5"
                                                Margin="0,0,10,0"
                                                Visibility="{Binding Status, Converter={StaticResource DownloadStatusToVisibilityConverter}}"/>
                                        <Button Content="Remove"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding DataContext.RemoveDownloadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Padding="10,5"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Downloaded Files Section -->
        <Grid Grid.Row="3" Margin="0,20,0,15">
            <TextBlock Text="Ready to Install"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>

            <Button Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding RefreshDownloadedFilesCommand}"
                    HorizontalAlignment="Right"
                    Padding="15,5"><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="RefreshCw" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Refresh" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel></Button>
        </Grid>

        <ScrollViewer Grid.Row="4"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding DownloadedFiles}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ModernCardStyle}"
                                Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Text>
                                            <Binding Path="." Converter="{StaticResource FileNameConverter}"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Converter={StaticResource FilePathConverter}}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,3,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal">
                                    <Button Command="{Binding DataContext.InstallFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,10,0"
                                            Padding="15,8"><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="Package" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Install" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel></Button>
                                    <Button Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding DataContext.DeleteFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Padding="10,8"><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="Trash2" Width="14" Height="14" VerticalAlignment="Center"/></StackPanel></Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <!-- Download History Section -->
        <Grid Grid.Row="5" Margin="0,20,0,10">
            <TextBlock Text="Download History"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <Button Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding ClearHistoryCommand}"
                    HorizontalAlignment="Right"
                    Padding="15,5"><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="Trash2" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Clear History" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel></Button>
        </Grid>

        <ScrollViewer Grid.Row="6" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding DownloadHistory}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding GameName}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                        <TextBlock Text="{Binding Mode}"
                                                   FontSize="11" Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding AppId, StringFormat='App {0}'}"
                                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                                        <TextBlock Text="{Binding SizeFormatted}"
                                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                                        <TextBlock Text="{Binding DurationFormatted}"
                                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                                        <TextBlock Text="{Binding DateFormatted}"
                                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Column="1" CornerRadius="4" Padding="10,4" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#2d7d46"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                    <Setter Property="Background" Value="#c0392b"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>

<UserControl x:Class="HubcapManifestApp.Views.CloudSetupPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Loaded="OnLoaded">
    <Grid Margin="0,10,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Patch Steam to enable CloudRedirect and manage your setup."
                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,15"/>

        <!-- Steam Path + Browse (Fix #3) -->
        <Border Grid.Row="1" Style="{StaticResource ModernCardStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Steam Path:" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Grid.Column="1" Text="{Binding SteamPathDisplay}" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <Button Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding BrowseSteamPathCommand}" Padding="12,5" Margin="10,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconLucide Kind="FolderSearch" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Browse" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Status -->
        <WrapPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,10,10" MinWidth="220">
                <StackPanel>
                    <TextBlock Text="Steam Version" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SteamVersionStatus}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,10,10" MinWidth="180">
                <StackPanel>
                    <TextBlock Text="Core DLL" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding PatchStatus}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,10,10" MinWidth="180">
                <StackPanel>
                    <TextBlock Text="Offline Setup" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding OfflineStatus}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,10,10" MinWidth="180">
                <StackPanel>
                    <TextBlock Text="SteamTools.exe" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SteamToolsStatus}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,10" MinWidth="180">
                <StackPanel>
                    <TextBlock Text="DLL Status" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding DllStatus}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Version mismatch warning -->
        <Border Grid.Row="3" CornerRadius="6" Margin="0,0,0,10"
                Visibility="{Binding IsVersionMismatch, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Border CornerRadius="6" Background="{DynamicResource WarningBrush}" Opacity="0.15"/>
                <StackPanel Orientation="Horizontal" Margin="12,8">
                    <iconPacks:PackIconLucide Kind="TriangleAlert" Width="16" Height="16" VerticalAlignment="Center"
                                              Foreground="{DynamicResource WarningBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="Steam version mismatch — patching is disabled until the correct version is installed."
                               Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Actions -->
        <WrapPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Command="{Binding RunAllPatchesCommand}" Padding="20,10" Margin="0,0,8,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsVersionMismatch}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSteamMissing}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="Zap" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Run All Patches" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel>
            </Button>
            <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RefreshStatusCommand}" Padding="15,8" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="RefreshCw" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Refresh" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel>
            </Button>
            <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ClearLogCommand}" Padding="15,8">
                <StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="Trash2" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Clear Log" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel>
            </Button>
        </WrapPanel>

        <!-- Log -->
        <Border Grid.Row="5" Style="{StaticResource ModernCardStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True" Background="Transparent"
                         BorderThickness="0" Foreground="{DynamicResource TextSecondaryBrush}"
                         FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Disabled" CaretBrush="{DynamicResource TextPrimaryBrush}"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>

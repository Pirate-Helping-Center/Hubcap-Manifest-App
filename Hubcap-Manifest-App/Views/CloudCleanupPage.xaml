<UserControl x:Class="HubcapManifestApp.Views.CloudCleanupPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <Grid Margin="0,10,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Action buttons -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Scan for SteamTools cloud contamination and clean up polluted files."
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,15"/>
            <WrapPanel Orientation="Horizontal">
                <Button Command="{Binding RunScanCommand}" Padding="20,8" Margin="0,0,8,0"
                        IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBooleanConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconLucide Kind="Search" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Scan" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ViewBackupsCommand}" Padding="15,8" Margin="0,0,8,0"
                        IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBooleanConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconLucide Kind="FolderArchive" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text="View Backups" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ClearLogCommand}" Padding="15,8">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconLucide Kind="Trash2" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Clear Log" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                </Button>
            </WrapPanel>
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Scrollable content area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ═══ Scan Results (per-app cards) ═══ -->
                <ItemsControl ItemsSource="{Binding ScanResults}"
                              Visibility="{Binding ShowingScanResults, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,8">
                                <StackPanel>
                                    <!-- ── App header row: icon + name/stats + expand button ── -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Game header image -->
                                        <Border Grid.Column="0" Background="{DynamicResource SecondaryDarkBrush}"
                                                CornerRadius="6" Width="180" Height="84" Margin="0,0,12,0"
                                                VerticalAlignment="Center">
                                            <Grid>
                                                <Image Source="{Binding CachedIconPath}"
                                                       Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="LowQuality"
                                                       Visibility="{Binding CachedIconPath, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                <iconPacks:PackIconLucide Kind="Gamepad2" Width="32" Height="32"
                                                                          Foreground="{DynamicResource AccentBrush}"
                                                                          VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                          Visibility="{Binding CachedIconPath, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                                            </Grid>
                                        </Border>

                                        <!-- Name + stats -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <TextBlock Text="{Binding StatsLine}" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                                                <TextBlock Text="{Binding SuspectStatsLine}" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasPollution}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Expand/collapse button -->
                                        <Button Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding ToggleExpandCommand}"
                                                Padding="15,8" VerticalAlignment="Center" Margin="8,0,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconLucide Width="14" Height="14" VerticalAlignment="Center">
                                                    <iconPacks:PackIconLucide.Style>
                                                        <Style TargetType="iconPacks:PackIconLucide">
                                                            <Setter Property="Kind" Value="Eye"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasPollution}" Value="True">
                                                                    <Setter Property="Kind" Value="Search"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                    <Setter Property="Kind" Value="ChevronUp"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </iconPacks:PackIconLucide.Style>
                                                </iconPacks:PackIconLucide>
                                                <TextBlock Text="{Binding ExpandButtonText}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <!-- ── Expandable file detail panel ── -->
                                    <StackPanel Margin="0,12,0,0"
                                                Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">

                                        <!-- Suspect Files Section -->
                                        <StackPanel Visibility="{Binding HasSuspectFiles, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="{Binding SuspectHeader}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <ItemsControl ItemsSource="{Binding SuspectFiles}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,1,0,1">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsChecked}"
                                                                      VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding RelativePath}"
                                                                       FontFamily="Cascadia Code,Consolas,Courier New" FontSize="12"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding Reason}" Margin="0,0,8,0"/>
                                                            <Border Grid.Column="2" CornerRadius="4" Padding="6,2,6,2"
                                                                    Margin="0,0,8,0" VerticalAlignment="Center"
                                                                    Background="{Binding BadgeColor, Converter={StaticResource ResourceKeyToBrushConverter}}">
                                                                <TextBlock Text="{Binding ClassificationLabel}" FontSize="11"
                                                                           Foreground="White"/>
                                                            </Border>
                                                            <TextBlock Grid.Column="3" Text="{Binding SizeFormatted}" FontSize="12"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       VerticalAlignment="Center" MinWidth="60"
                                                                       TextAlignment="Right"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <!-- Unknown Files Section -->
                                        <StackPanel Visibility="{Binding HasUnknownFiles, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Margin="0,8,0,0">
                                            <TextBlock Text="{Binding UnknownHeader}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <ItemsControl ItemsSource="{Binding UnknownFiles}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,1,0,1">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsChecked}"
                                                                      VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding RelativePath}"
                                                                       FontFamily="Cascadia Code,Consolas,Courier New" FontSize="12"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding Reason}" Margin="0,0,8,0"/>
                                                            <Border Grid.Column="2" CornerRadius="4" Padding="6,2,6,2"
                                                                    Margin="0,0,8,0" VerticalAlignment="Center"
                                                                    Background="{Binding BadgeColor, Converter={StaticResource ResourceKeyToBrushConverter}}">
                                                                <TextBlock Text="{Binding ClassificationLabel}" FontSize="11"
                                                                           Foreground="White"/>
                                                            </Border>
                                                            <TextBlock Grid.Column="3" Text="{Binding SizeFormatted}" FontSize="12"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       VerticalAlignment="Center" MinWidth="60"
                                                                       TextAlignment="Right"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <!-- Legitimate Files Section -->
                                        <StackPanel Visibility="{Binding HasLegitimateFiles, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Margin="0,8,0,0">
                                            <TextBlock Text="{Binding LegitimateHeader}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <ItemsControl ItemsSource="{Binding LegitimateFiles}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,1,0,1">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="26"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <!-- No checkbox — just empty space to align with other sections -->
                                                            <TextBlock Grid.Column="1" Text="{Binding RelativePath}"
                                                                       FontFamily="Cascadia Code,Consolas,Courier New" FontSize="12"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding Reason}" Margin="0,0,8,0"/>
                                                            <Border Grid.Column="2" CornerRadius="4" Padding="6,2,6,2"
                                                                    Margin="0,0,8,0" VerticalAlignment="Center"
                                                                    Background="{Binding BadgeColor, Converter={StaticResource ResourceKeyToBrushConverter}}">
                                                                <TextBlock Text="{Binding ClassificationLabel}" FontSize="11"
                                                                           Foreground="White"/>
                                                            </Border>
                                                            <TextBlock Grid.Column="3" Text="{Binding SizeFormatted}" FontSize="12"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       VerticalAlignment="Center" MinWidth="60"
                                                                       TextAlignment="Right"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <!-- Per-app action buttons (only when checkable files exist) -->
                                        <WrapPanel Margin="0,12,0,0"
                                                   Visibility="{Binding HasCheckboxes, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                                     Command="{Binding SelectAllSuspectCommand}"
                                                     Padding="12,6" Margin="0,0,8,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconLucide Kind="CheckCheck" Width="14" Height="14"
                                                                              VerticalAlignment="Center"/>
                                                    <TextBlock Text="Select All Suspect" VerticalAlignment="Center"
                                                               Margin="6,0,0,0"/>
                                                </StackPanel>
                                             </Button>
                                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                                     Command="{Binding DeselectAllCommand}"
                                                     Padding="12,6" Margin="0,0,8,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconLucide Kind="X" Width="14" Height="14"
                                                                              VerticalAlignment="Center"/>
                                                    <TextBlock Text="Deselect All" VerticalAlignment="Center"
                                                               Margin="6,0,0,0"/>
                                                </StackPanel>
                                             </Button>
                                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                                     Command="{Binding CleanSelectedCommand}"
                                                     Padding="12,6"
                                                     IsEnabled="{Binding IsCleaning, Converter={StaticResource InverseBooleanConverter}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconLucide Kind="Trash2" Width="14" Height="14"
                                                                              Foreground="{DynamicResource DangerBrush}"
                                                                              VerticalAlignment="Center"/>
                                                    <TextBlock Text="Clean Selected" VerticalAlignment="Center"
                                                               Margin="6,0,0,0"/>
                                                </StackPanel>
                                             </Button>
                                        </WrapPanel>

                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ═══ Backup list (card-based, matching scan results layout) ═══ -->
                <ItemsControl ItemsSource="{Binding Backups}"
                              Visibility="{Binding ShowingBackups, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Game header image -->
                                    <Border Grid.Column="0" Background="{DynamicResource SecondaryDarkBrush}"
                                            CornerRadius="6" Width="180" Height="84" Margin="0,0,12,0"
                                            VerticalAlignment="Center">
                                        <Grid>
                                            <Image Source="{Binding CachedIconPath}"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="LowQuality"
                                                   Visibility="{Binding CachedIconPath, Converter={StaticResource NullToVisibilityConverter}}"/>
                                            <iconPacks:PackIconLucide Kind="Gamepad2" Width="32" Height="32"
                                                                      Foreground="{DynamicResource AccentBrush}"
                                                                      VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                      Visibility="{Binding CachedIconPath, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                                        </Grid>
                                    </Border>

                                    <!-- Name + stats -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding StatsLine}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                                        <TextBlock Text="{Binding TimestampFormatted}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                                        <TextBlock Text="{Binding AppNames}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding AppNames}"/>
                                    </StackPanel>

                                    <!-- Restore button -->
                                    <Button Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding DataContext.RestoreBackupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Padding="12,6" VerticalAlignment="Center" Margin="8,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconLucide Kind="Undo2" Width="14" Height="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Restore" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ═══ Log output ═══ -->
                <TextBlock Text="Log" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,15,0,4"/>
                <Border Style="{StaticResource ModernCardStyle}" MinHeight="120">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                        <TextBox Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True" Background="Transparent"
                                 BorderThickness="0" Foreground="{DynamicResource TextSecondaryBrush}"
                                 FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Disabled" CaretBrush="{DynamicResource TextPrimaryBrush}"/>
                    </ScrollViewer>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

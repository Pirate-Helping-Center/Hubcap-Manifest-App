<UserControl x:Class="HubcapManifestApp.Views.SupportPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,30">
            <TextBlock Text="Support"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="800" HorizontalAlignment="Left">

                <!-- Logs Section -->
                <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15"><iconPacks:PackIconLucide Kind="ClipboardList" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Logs"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/></StackPanel>

                        <TextBlock Text="View application logs to troubleshoot issues or help with bug reports."
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,15"/>

                        <Button Command="{Binding OpenLogsFolderCommand}"
                                Padding="20,10"
                                HorizontalAlignment="Left"><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="FolderOpen" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Open Logs Folder" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel></Button>
                    </StackPanel>
                </Border>

                <!-- Community Section -->
                <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15"><iconPacks:PackIconLucide Kind="MessageSquare" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Community &amp; Support"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/></StackPanel>

                        <TextBlock Text="Join our Discord server for help, updates, and discussion with other users."
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,15"/>

                        <Button Command="{Binding OpenDiscordCommand}"
                                Padding="20,10"
                                HorizontalAlignment="Left"><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="MessageSquare" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Join Discord Server" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel></Button>
                    </StackPanel>
                </Border>

                <!-- GitHub Section -->
                <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15"><iconPacks:PackIconLucide Kind="Bug" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Report Issues"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/></StackPanel>

                        <TextBlock Text="Found a bug or have a feature request? Report it on GitHub."
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,15"/>

                        <Button Command="{Binding OpenGitHubCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="20,10"
                                HorizontalAlignment="Left"><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="Bug" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Open GitHub Repository" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel></Button>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

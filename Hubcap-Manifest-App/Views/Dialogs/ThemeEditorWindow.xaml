<Window x:Class="HubcapManifestApp.Views.Dialogs.ThemeEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="Theme Editor"
        Height="720" Width="1000"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        MinWidth="800" MinHeight="500">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      ResizeBorderThickness="5"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Compact color picker: a fixed-width swatch button instead of the default
             full-stretch bar. Label sits to its left, picker is just a chip. -->
        <Style TargetType="xctk:ColorPicker">
            <Setter Property="Width" Value="72"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="UsingAlphaChannel" Value="True"/>
        </Style>
        <!-- A color row: small label + compact swatch, packed tight. -->
        <Style x:Key="ColorRowText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource PrimaryDarkBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource TitleBarBackgroundBrush}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Theme Editor"
                               Foreground="{DynamicResource TitleBarTextBrush}"
                               FontWeight="Bold"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="12,0"/>
                    <Button HorizontalAlignment="Right"
                            Width="36" Height="36"
                            Background="Transparent"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderThickness="0"
                            Click="Close_Click"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Cursor="Hand">
                        <iconPacks:PackIconLucide Kind="X" Width="14" Height="14"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Main area: left preset list, right editor -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Presets pane -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SidebarBackgroundBrush}"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Presets"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,10"/>

                        <ListBox Grid.Row="1"
                                 x:Name="PresetList"
                                 ItemsSource="{Binding Presets}"
                                 SelectedItem="{Binding SelectedPreset}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource TextPrimaryBrush}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="13"
                                               Padding="6,6"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Padding="2">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BorderBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,10,0,0">
                            <Button Content="+ New"
                                    Click="NewPreset_Click"
                                    Margin="0,0,0,6"
                                    Padding="8,6"
                                    HorizontalAlignment="Stretch"/>
                            <Button Content="Duplicate"
                                    Click="DuplicatePreset_Click"
                                    Margin="0,0,0,6"
                                    Padding="8,6"
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                            <Button Content="Delete"
                                    Click="DeletePreset_Click"
                                    Padding="8,6"
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Editor pane -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel DataContext="{Binding SelectedPreset}">
                        <TextBlock Text="Preset Name" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,16" FontSize="14" Padding="8,6"/>

                        <!-- Backgrounds -->
                        <TextBlock Text="Backgrounds"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="16" FontWeight="Bold"
                                   Margin="0,8,0,8"/>

                        <UniformGrid Columns="2">
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <xctk:ColorPicker SelectedColor="{Binding PageBackground, Converter={StaticResource HexToColorConverter}}"/>
                                <TextBlock Text="Page" Style="{StaticResource ColorRowText}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <xctk:ColorPicker SelectedColor="{Binding SidebarBackground, Converter={StaticResource HexToColorConverter}}"/>
                                <TextBlock Text="Sidebar" Style="{StaticResource ColorRowText}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <xctk:ColorPicker SelectedColor="{Binding TitleBarBackground, Converter={StaticResource HexToColorConverter}}"/>
                                <TextBlock Text="Title bar" Style="{StaticResource ColorRowText}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <xctk:ColorPicker SelectedColor="{Binding CardBackground, Converter={StaticResource HexToColorConverter}}"/>
                                <TextBlock Text="Card" Style="{StaticResource ColorRowText}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <xctk:ColorPicker SelectedColor="{Binding CardHover, Converter={StaticResource HexToColorConverter}}"/>
                                <TextBlock Text="Card hover" Style="{StaticResource ColorRowText}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <xctk:ColorPicker SelectedColor="{Binding SecondaryBackground, Converter={StaticResource HexToColorConverter}}"/>
                                <TextBlock Text="Elevated / secondary" Style="{StaticResource ColorRowText}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <xctk:ColorPicker SelectedColor="{Binding Border, Converter={StaticResource HexToColorConverter}}"/>
                                <TextBlock Text="Border" Style="{StaticResource ColorRowText}" Margin="8,0,0,0"/>
                            </StackPanel>
                        </UniformGrid>

                        <!-- Background images -->
                        <TextBlock Text="Background Images"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="16" FontWeight="Bold"
                                   Margin="0,18,0,8"/>
                        <TextBlock Text="Recommended: 1920×1080 (page), 300×1080 (sidebar). PNG or JPG."
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11"
                                   Margin="0,0,0,8"/>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Page background image" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBox Grid.Column="1" Text="{Binding PageBackgroundImagePath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Padding="8,6"/>
                            <Button Grid.Column="2" Content="..." Click="ChoosePageImage_Click" Padding="10,6" Margin="6,0,0,0"/>
                            <Button Grid.Column="3" Content="Clear" Click="ClearPageImage_Click" Padding="10,6" Margin="6,0,0,0" Style="{StaticResource SecondaryButtonStyle}"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Page image fit" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <ComboBox Grid.Column="1" SelectedItem="{Binding PageBackgroundImageFit}" ItemsSource="{Binding ImageFitOptions, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </Grid>

                        <Grid Margin="0,10,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sidebar background image" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBox Grid.Column="1" Text="{Binding SidebarBackgroundImagePath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Padding="8,6"/>
                            <Button Grid.Column="2" Content="..." Click="ChooseSidebarImage_Click" Padding="10,6" Margin="6,0,0,0"/>
                            <Button Grid.Column="3" Content="Clear" Click="ClearSidebarImage_Click" Padding="10,6" Margin="6,0,0,0" Style="{StaticResource SecondaryButtonStyle}"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sidebar image fit" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <ComboBox Grid.Column="1" SelectedItem="{Binding SidebarBackgroundImageFit}" ItemsSource="{Binding ImageFitOptions, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </Grid>

                        <!-- Text -->
                        <TextBlock Text="Text"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="16" FontWeight="Bold"
                                   Margin="0,18,0,8"/>

                        <UniformGrid Columns="2">
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <xctk:ColorPicker SelectedColor="{Binding TextPrimary, Converter={StaticResource HexToColorConverter}}"/>
                                <TextBlock Text="Primary text" Style="{StaticResource ColorRowText}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <xctk:ColorPicker SelectedColor="{Binding TextSecondary, Converter={StaticResource HexToColorConverter}}"/>
                                <TextBlock Text="Secondary text" Style="{StaticResource ColorRowText}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <xctk:ColorPicker SelectedColor="{Binding TitleBarText, Converter={StaticResource HexToColorConverter}}"/>
                                <TextBlock Text="Title bar text" Style="{StaticResource ColorRowText}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <xctk:ColorPicker SelectedColor="{Binding ButtonText, Converter={StaticResource HexToColorConverter}}"/>
                                <TextBlock Text="Button text" Style="{StaticResource ColorRowText}" Margin="8,0,0,0"/>
                            </StackPanel>
                        </UniformGrid>

                        <!-- Buttons & Accent -->
                        <TextBlock Text="Buttons &amp; Accent"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="16" FontWeight="Bold"
                                   Margin="0,18,0,8"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <RadioButton Content="Solid color"
                                         IsChecked="{Binding AccentMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Solid}"
                                         Margin="0,0,16,0"/>
                            <RadioButton Content="Gradient"
                                         IsChecked="{Binding AccentMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Gradient}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,4"
                                    Visibility="{Binding AccentMode, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Solid}">
                            <xctk:ColorPicker SelectedColor="{Binding Accent, Converter={StaticResource HexToColorConverter}}"/>
                            <TextBlock Text="Button / accent color" Style="{StaticResource ColorRowText}" Margin="8,0,0,0"/>
                        </StackPanel>

                        <StackPanel Visibility="{Binding AccentMode, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Gradient}">
                            <!-- Live gradient preview bar -->
                            <Border x:Name="GradientPreviewBorder"
                                    Height="28"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Margin="0,4,0,10"
                                    Background="{DynamicResource AccentBrush}"/>

                            <TextBlock Text="Drag each slider to set where the color lands along the gradient (0% = start, 100% = end)."
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding AccentGradientStops}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <xctk:ColorPicker Grid.Column="0"
                                                              Width="40"
                                                              SelectedColor="{Binding Color, Converter={StaticResource HexToColorConverter}}"
                                                              UsingAlphaChannel="True"/>
                                            <Slider Grid.Column="1"
                                                    Minimum="0" Maximum="1"
                                                    SmallChange="0.01" LargeChange="0.1"
                                                    TickFrequency="0.1"
                                                    Value="{Binding Offset, UpdateSourceTrigger=PropertyChanged}"
                                                    Margin="8,0,8,0"
                                                    VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Offset, StringFormat='{}{0:P0}'}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"
                                                       FontSize="11"/>
                                            <Button Grid.Column="3"
                                                    Tag="{Binding}"
                                                    Click="RemoveStop_Click"
                                                    Padding="8,4"
                                                    Margin="8,0,0,0"
                                                    Style="{StaticResource SecondaryButtonStyle}">
                                                <iconPacks:PackIconLucide Kind="X" Width="12" Height="12"/>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="+ Add stop"
                                        Click="AddStop_Click"
                                        Padding="10,6"
                                        Margin="0,0,8,0"/>
                                <Button Content="Distribute evenly"
                                        Click="DistributeStops_Click"
                                        Padding="10,6"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                            </StackPanel>

                            <Grid Margin="0,14,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Gradient angle" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <Slider Grid.Column="1"
                                        Minimum="0" Maximum="360"
                                        SmallChange="1" LargeChange="15"
                                        TickFrequency="15"
                                        Value="{Binding AccentGradientAngle, UpdateSourceTrigger=PropertyChanged}"
                                        VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding AccentGradientAngle, StringFormat='{}{0:F0}°'}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           FontSize="12"/>
                            </Grid>
                        </StackPanel>

                        <!-- Sidebar active -->
                        <TextBlock Text="Sidebar Active Item"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="16" FontWeight="Bold"
                                   Margin="0,18,0,8"/>

                        <UniformGrid Columns="2">
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <xctk:ColorPicker SelectedColor="{Binding SidebarActive, Converter={StaticResource HexToColorConverter}}"/>
                                <TextBlock Text="Active background" Style="{StaticResource ColorRowText}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <xctk:ColorPicker SelectedColor="{Binding SidebarActiveText, Converter={StaticResource HexToColorConverter}}"/>
                                <TextBlock Text="Active text" Style="{StaticResource ColorRowText}" Margin="8,0,0,0"/>
                            </StackPanel>
                        </UniformGrid>

                        <!-- Status -->
                        <TextBlock Text="Status"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="16" FontWeight="Bold"
                                   Margin="0,18,0,8"/>

                        <UniformGrid Columns="3" Margin="0,0,0,24">
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <xctk:ColorPicker SelectedColor="{Binding Success, Converter={StaticResource HexToColorConverter}}"/>
                                <TextBlock Text="Success" Style="{StaticResource ColorRowText}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <xctk:ColorPicker SelectedColor="{Binding Warning, Converter={StaticResource HexToColorConverter}}"/>
                                <TextBlock Text="Warning" Style="{StaticResource ColorRowText}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <xctk:ColorPicker SelectedColor="{Binding Danger, Converter={StaticResource HexToColorConverter}}"/>
                                <TextBlock Text="Danger" Style="{StaticResource ColorRowText}" Margin="8,0,0,0"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    Padding="12">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Export to clipboard"
                                Click="Export_Click"
                                Padding="12,6"
                                Margin="0,0,8,0"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                        <Button Content="Import from clipboard"
                                Click="Import_Click"
                                Padding="12,6"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Apply"
                                Click="Apply_Click"
                                Padding="16,6"
                                Margin="0,0,8,0"/>
                        <Button Content="Save &amp; Close"
                                Click="SaveAndClose_Click"
                                Padding="16,6"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

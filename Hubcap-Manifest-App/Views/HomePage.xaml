<UserControl x:Class="HubcapManifestApp.Views.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:converters="clr-namespace:HubcapManifestApp.Converters"
             Loaded="OnLoaded">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30,20,30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header Row -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Hubcap Manifest App"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="Steam Depot Manager &amp; Tools"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Command="{Binding LaunchSteamCommand}" Padding="20,10" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconLucide Kind="Rocket" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Launch Steam" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ToggleModeCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="12,10" ToolTip="Click to switch mode">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconLucide Kind="ArrowLeftRight" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding CurrentModeText}" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Stats Grid - 2 rows of cards -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource ModernCardStyle}" Margin="0,0,6,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding LibraryCount}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Games in Library" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ModernCardStyle}" Margin="3,0,3,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding LuaCount}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Lua Files"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LuaCount}" Value="0">
                                            <Setter Property="Text" Value="No luas installed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource ModernCardStyle}" Margin="3,0,3,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding TotalSize}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Total Size" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource ModernCardStyle}" Margin="6,0,0,0"
                        Visibility="{Binding HasApiStats, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding DailyUsage}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock Text="{Binding DailyLimit, StringFormat=' / {0}'}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Bottom" Margin="0,0,0,5"/>
                        </StackPanel>
                        <TextBlock Text="API Calls Today" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Recently Added to Store -->
            <TextBlock Grid.Row="2" Text="Recently Added to Store"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,10"/>

            <ItemsControl Grid.Row="3" ItemsSource="{Binding RecentlyAdded}" Margin="0,0,0,20">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,6,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Game Image (natural aspect, fills card width) -->
                                <Border Grid.Row="0" Background="{DynamicResource SecondaryDarkBrush}" CornerRadius="6">
                                    <Image Source="{Binding CachedIconPath}" Stretch="Uniform"/>
                                </Border>

                                <!-- Game Name -->
                                <TextBlock Grid.Row="1" Text="{Binding GameName}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis" Margin="0,8,0,0"/>

                                <!-- Date + Size -->
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,3,0,0">
                                    <TextBlock Text="{Binding UploadedDate, StringFormat='{}{0:MMM d}'}"
                                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text=" · " FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding GameId, StringFormat='App {0}'}"
                                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>

                                <!-- Download Button -->
                                <Button Grid.Row="3"
                                        Command="{Binding DataContext.DownloadRecentGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="8,5" Margin="0,8,0,0"
                                        HorizontalAlignment="Stretch" FontSize="11">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <iconPacks:PackIconLucide Kind="Download" Width="12" Height="12" VerticalAlignment="Center"/>
                                        <TextBlock Text="Download" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Recent Downloads + Steam Path -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Downloads -->
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Recent Downloads"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding RecentDownloads}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding GameName}" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                                                <Run Text="{Binding Mode, Mode=OneWay}" Foreground="{DynamicResource AccentBrush}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding SizeFormatted, Mode=OneWay}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding DateFormatted, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Border Grid.Column="1" CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#2d7d46"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                            <Setter Property="Background" Value="#c0392b"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}" FontSize="10" Foreground="White"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="No download history yet"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontStyle="Italic"
                               Margin="0,4,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RecentDownloads.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Quick Info Sidebar -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Quick Info"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,10"/>
                    <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,6">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <iconPacks:PackIconLucide Kind="HardDrive" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="Steam Path" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SteamPath}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,6">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <iconPacks:PackIconLucide Kind="Gamepad2" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="Steam Games" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SteamGameCount, StringFormat='{}{0} games detected'}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ModernCardStyle}"
                            Visibility="{Binding HasApiStats, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <iconPacks:PackIconLucide Kind="Zap" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="API Status" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                                <Run Text="{Binding DailyRemaining, Mode=OneWay}"/><Run Text=" downloads remaining today"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>

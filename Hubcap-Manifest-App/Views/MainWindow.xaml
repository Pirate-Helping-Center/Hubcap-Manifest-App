<Window x:Class="HubcapManifestApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:viewmodels="clr-namespace:HubcapManifestApp.ViewModels"
        xmlns:views="clr-namespace:HubcapManifestApp.Views"
        Title="Hubcap Manifest App"
        Height="900"
        Width="1200"
        MinHeight="600"
        MinWidth="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{DynamicResource TextPrimaryBrush}"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      ResizeBorderThickness="5"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
    </Window.Resources>

    <Border Background="{DynamicResource PrimaryDarkBrush}"
            CornerRadius="0"
            BorderBrush="{DynamicResource SecondaryDarkBrush}"
            BorderThickness="1">
        <Grid>
            <!-- Main Layout -->
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <!-- Title Bar -->
                <RowDefinition Height="*"/>
                <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource TitleBarBackgroundBrush}"
                    CornerRadius="0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="12,0">
                        <TextBlock Text="Hubcap Manifest App"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TitleBarTextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window Controls -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Width="36" Height="28"
                                Background="Transparent"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                BorderThickness="0"
                                Padding="0"
                                Click="MinimizeButton_Click"
                                Cursor="Hand"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        Width="36" Height="28"
                                                        Padding="0">
                                                    <iconPacks:PackIconLucide Kind="Minus" Width="12" Height="12" Foreground="{TemplateBinding Foreground}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#40FFFFFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Width="36" Height="28"
                                Background="Transparent"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                BorderThickness="0"
                                Padding="0"
                                Click="MaximizeButton_Click"
                                Cursor="Hand"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        Width="36" Height="28"
                                                        Padding="0">
                                                    <iconPacks:PackIconLucide Kind="Square" Width="11" Height="11" Foreground="{TemplateBinding Foreground}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#40FFFFFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Width="36" Height="28"
                                Background="Transparent"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                BorderThickness="0"
                                Padding="0"
                                Click="CloseButton_Click"
                                Cursor="Hand"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        Width="36" Height="28"
                                                        Padding="0">
                                                    <iconPacks:PackIconLucide Kind="X" Width="12" Height="12" Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#40FF0000"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <!-- Sidebar -->
                    <ColumnDefinition Width="*"/>
                    <!-- Content -->
                </Grid.ColumnDefinitions>

                <!-- Sidebar Navigation.
                     Uses its own themed brush so custom themes can paint it separately
                     from the page background (including image backgrounds). Built-in
                     themes default SidebarBackgroundBrush to SecondaryDark. -->
                <Border Grid.Column="0"
                        Background="Transparent"
                        CornerRadius="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="5">
                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToHomeCommand}"
                                Tag="{Binding CurrentPageName, Converter={StaticResource PageNameToTagConverter}, ConverterParameter=Home}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconLucide Kind="Home" Width="14" Height="14" Margin="0,0,6,0" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Text="Home" FontSize="13" Style="{StaticResource NavLabelStyle}"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToInstallerCommand}"
                                Tag="{Binding CurrentPageName, Converter={StaticResource PageNameToTagConverter}, ConverterParameter=Installer}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconLucide Kind="Package" Width="14" Height="14" Margin="0,0,6,0" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Text="Installer" FontSize="13" Style="{StaticResource NavLabelStyle}"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToLibraryCommand}"
                                Tag="{Binding CurrentPageName, Converter={StaticResource PageNameToTagConverter}, ConverterParameter=Library}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconLucide Kind="Library" Width="14" Height="14" Margin="0,0,6,0" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Text="Library" FontSize="13" Style="{StaticResource NavLabelStyle}"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToStoreCommand}"
                                Tag="{Binding CurrentPageName, Converter={StaticResource PageNameToTagConverter}, ConverterParameter=Store}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconLucide Kind="ShoppingCart" Width="14" Height="14" Margin="0,0,6,0" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Text="Store" FontSize="13" Style="{StaticResource NavLabelStyle}"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToDownloadsCommand}"
                                Tag="{Binding CurrentPageName, Converter={StaticResource PageNameToTagConverter}, ConverterParameter=Downloads}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconLucide Kind="Download" Width="14" Height="14" Margin="0,0,6,0" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Text="Downloads" FontSize="13" Style="{StaticResource NavLabelStyle}"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToWorkshopCommand}"
                                Tag="{Binding CurrentPageName, Converter={StaticResource PageNameToTagConverter}, ConverterParameter=Workshop}"
                                Visibility="{Binding ShowWorkshop, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconLucide Kind="Hammer" Width="14" Height="14" Margin="0,0,6,0" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Text="Workshop" FontSize="13" Style="{StaticResource NavLabelStyle}"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToCloudCommand}"
                                Tag="{Binding CurrentPageName, Converter={StaticResource PageNameToTagConverter}, ConverterParameter=Cloud}"
                                Visibility="{Binding ShowCloudSaves, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconLucide Kind="Cloud" Width="14" Height="14" Margin="0,0,6,0" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Text="Cloud Saves" FontSize="13" Style="{StaticResource NavLabelStyle}"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToToolsCommand}"
                                Tag="{Binding CurrentPageName, Converter={StaticResource PageNameToTagConverter}, ConverterParameter=Tools}"
                                Visibility="{Binding ShowTools, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconLucide Kind="Wrench" Width="14" Height="14" Margin="0,0,6,0" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Text="Tools" FontSize="13" Style="{StaticResource NavLabelStyle}"/>
                            </StackPanel>
                        </Button>

                        <Separator Background="{DynamicResource CardBackgroundBrush}"
                                   Margin="3,12"/>

                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToSettingsCommand}"
                                Tag="{Binding CurrentPageName, Converter={StaticResource PageNameToTagConverter}, ConverterParameter=Settings}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconLucide Kind="Settings" Width="14" Height="14" Margin="0,0,6,0" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Text="Settings" FontSize="13" Style="{StaticResource NavLabelStyle}"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToSupportCommand}"
                                Tag="{Binding CurrentPageName, Converter={StaticResource PageNameToTagConverter}, ConverterParameter=Support}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconLucide Kind="CircleHelp" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Support" FontSize="13"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Bottom Actions -->
                    <Border Grid.Row="1"
                            Margin="5,0,5,8">
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding RestartSteamCommand}"
                                HorizontalAlignment="Stretch"
                                Height="36"
                                FontSize="12"
                                ToolTip="Restart Steam"><StackPanel Orientation="Horizontal"><iconPacks:PackIconLucide Kind="RefreshCw" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text="Restart" VerticalAlignment="Center" Margin="6,0,0,0"/></StackPanel></Button>
                    </Border>
                </Grid>
                </Border>

                <!-- Page Content -->
                <ContentControl Grid.Column="1"
                                Content="{Binding CurrentPage}"
                                Margin="0"/>
            </Grid>
        </Grid>
    </Border>
</Window>

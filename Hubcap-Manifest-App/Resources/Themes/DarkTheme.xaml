<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- True Dark Mode Theme -->
    <Color x:Key="PrimaryDark">#0a0a0a</Color>
    <Color x:Key="SecondaryDark">#1a1a1a</Color>
    <Color x:Key="CardBackground">#050505</Color>
    <Color x:Key="CardHover">#0f0f0f</Color>
    <Color x:Key="Accent">#b0b0b0</Color>
    <Color x:Key="AccentHover">#d0d0d0</Color>
    <Color x:Key="BorderColor">#3a3a3a</Color>
    <Color x:Key="TextPrimary">#e0e0e0</Color>
    <Color x:Key="TextSecondary">#888888</Color>
    <Color x:Key="Success">#4CAF50</Color>
    <Color x:Key="Warning">#FFC107</Color>
    <Color x:Key="Danger">#F44336</Color>

    <!-- Solid Color Brushes -->
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDark}"/>
    <SolidColorBrush x:Key="SecondaryDarkBrush" Color="{StaticResource SecondaryDark}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="CardHoverBrush" Color="{StaticResource CardHover}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <!-- Dark theme buttons are light grey; use black text so they're actually readable. -->
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>

    <!-- Gradient Brushes -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#b0b0b0" Offset="0"/>
        <GradientStop Color="#d0d0d0" Offset="1"/>
    </LinearGradientBrush>


    <!-- Extended brushes for preset-based custom themes. Default to existing brushes
         so built-in themes render identically to before. -->
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SecondaryDark}"/>
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="TitleBarTextBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="SidebarActiveTextBrush" Color="#FF000000"/>

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="PrimaryDark">#1a1a2e</Color>
    <Color x:Key="SecondaryDark">#242440</Color>
    <Color x:Key="CardBackground">#12121f</Color>
    <Color x:Key="CardHover">#1e1e35</Color>
    <Color x:Key="Accent">#ff6b6b</Color>
    <Color x:Key="AccentHover">#ee5a5a</Color>
    <Color x:Key="TextPrimary">#e8e8f0</Color>
    <Color x:Key="TextSecondary">#9a9ab0</Color>
    <Color x:Key="BorderColor">#3a3a5c</Color>
    <Color x:Key="Success">#69db7c</Color>
    <Color x:Key="Warning">#ffd43b</Color>
    <Color x:Key="Danger">#ff6b6b</Color>

    <!-- Mid-saturation rainbow backgrounds. Same hues as the button accent gradient
         but knocked down ~55% brightness so the whole window reads as a rich
         rainbow without being eye-blinding pastel. -->
    <LinearGradientBrush x:Key="PrimaryDarkBrush" StartPoint="0,0" EndPoint="1,0" ColorInterpolationMode="ScRgbLinearInterpolation">
        <GradientStop Color="#6a2c30" Offset="0.00"/>
        <GradientStop Color="#6a3f2a" Offset="0.16"/>
        <GradientStop Color="#6a5e2a" Offset="0.33"/>
        <GradientStop Color="#356a36" Offset="0.50"/>
        <GradientStop Color="#2a526a" Offset="0.66"/>
        <GradientStop Color="#3a4070" Offset="0.83"/>
        <GradientStop Color="#562a6a" Offset="1.00"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SecondaryDarkBrush" StartPoint="0,0" EndPoint="1,0" ColorInterpolationMode="ScRgbLinearInterpolation">
        <GradientStop Color="#7a3238" Offset="0.00"/>
        <GradientStop Color="#7a4a32" Offset="0.16"/>
        <GradientStop Color="#7a6c32" Offset="0.33"/>
        <GradientStop Color="#3d7a3f" Offset="0.50"/>
        <GradientStop Color="#32607a" Offset="0.66"/>
        <GradientStop Color="#424a80" Offset="0.83"/>
        <GradientStop Color="#62327a" Offset="1.00"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="CardBackgroundBrush" StartPoint="0,0" EndPoint="1,0" ColorInterpolationMode="ScRgbLinearInterpolation">
        <GradientStop Color="#572228" Offset="0.00"/>
        <GradientStop Color="#573322" Offset="0.16"/>
        <GradientStop Color="#574d22" Offset="0.33"/>
        <GradientStop Color="#2b572c" Offset="0.50"/>
        <GradientStop Color="#224457" Offset="0.66"/>
        <GradientStop Color="#30365c" Offset="0.83"/>
        <GradientStop Color="#462257" Offset="1.00"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="CardHoverBrush" StartPoint="0,0" EndPoint="1,0" ColorInterpolationMode="ScRgbLinearInterpolation">
        <GradientStop Color="#6a2a32" Offset="0.00"/>
        <GradientStop Color="#6a3f2a" Offset="0.16"/>
        <GradientStop Color="#6a5e2a" Offset="0.33"/>
        <GradientStop Color="#356a36" Offset="0.50"/>
        <GradientStop Color="#2a526a" Offset="0.66"/>
        <GradientStop Color="#3a4070" Offset="0.83"/>
        <GradientStop Color="#562a6a" Offset="1.00"/>
    </LinearGradientBrush>
    <!-- Bright pastel rainbow accent so buttons read with black text -->
    <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,0" ColorInterpolationMode="ScRgbLinearInterpolation">
        <GradientStop Color="#ff9aa2" Offset="0.00"/>
        <GradientStop Color="#ffc18a" Offset="0.16"/>
        <GradientStop Color="#fff48a" Offset="0.33"/>
        <GradientStop Color="#9be59b" Offset="0.50"/>
        <GradientStop Color="#9bd5ff" Offset="0.66"/>
        <GradientStop Color="#b1b8ff" Offset="0.83"/>
        <GradientStop Color="#d9a4ff" Offset="1.00"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AccentHoverBrush" StartPoint="0,0" EndPoint="1,0" ColorInterpolationMode="ScRgbLinearInterpolation">
        <GradientStop Color="#ffb3b8" Offset="0.00"/>
        <GradientStop Color="#ffd1a3" Offset="0.16"/>
        <GradientStop Color="#fff7a3" Offset="0.33"/>
        <GradientStop Color="#b1ecb1" Offset="0.50"/>
        <GradientStop Color="#b1deff" Offset="0.66"/>
        <GradientStop Color="#c4caff" Offset="0.83"/>
        <GradientStop Color="#e3b8ff" Offset="1.00"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1" ColorInterpolationMode="ScRgbLinearInterpolation">
        <GradientStop Color="#ff6b6b" Offset="0"/>
        <GradientStop Color="#feca57" Offset="0.25"/>
        <GradientStop Color="#48dbfb" Offset="0.5"/>
        <GradientStop Color="#ff9ff3" Offset="0.75"/>
        <GradientStop Color="#ff6b6b" Offset="1"/>
    </LinearGradientBrush>


    <!-- Extended brushes for preset-based custom themes. Default to existing brushes
         so built-in themes render identically to before. -->
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SecondaryDark}"/>
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="TitleBarTextBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="SidebarActiveTextBrush" Color="#FFFFFFFF"/>

</ResourceDictionary>
